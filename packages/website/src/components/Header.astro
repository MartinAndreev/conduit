---
import {
  isActiveNavigationPath,
  navigationItems,
  withBase,
} from "../data/navigation.js";

interface Props {
  readonly base: string;
  readonly currentPath: string;
}

const { base, currentPath } = Astro.props;
const drawerId = "site-navigation-drawer";
---

<header class="site-header" data-site-header>
  <a class="brand" href={base} aria-label="Conduit home">
    <img src={`${base}conduit-logo.svg`} alt="Conduit" />
  </a>

  <nav class="primary-nav" aria-label="Primary navigation">
    {
      navigationItems.map((item) => (
        <a
          href={withBase(base, item.path)}
          aria-current={
            isActiveNavigationPath(currentPath, item) ? "page" : undefined
          }
          rel={item.external ? "noreferrer" : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>

  <button
    class="mobile-menu-button"
    type="button"
    aria-label="Open navigation"
    aria-expanded="false"
    aria-controls={drawerId}
    data-drawer-open
  >
    <span></span><span></span><span></span>
  </button>

  <div class="mobile-drawer-layer" data-drawer-layer hidden>
    <button
      class="mobile-drawer-backdrop"
      type="button"
      tabindex="-1"
      aria-label="Close navigation"
      data-drawer-backdrop
    ></button>
    <aside
      class="mobile-drawer"
      id={drawerId}
      aria-label="Mobile navigation"
      aria-modal="true"
      role="dialog"
      tabindex="-1"
      data-drawer
    >
      <div class="mobile-drawer-heading">
        <span>Navigation</span>
        <button
          class="mobile-drawer-close"
          type="button"
          aria-label="Close navigation"
          data-drawer-close
        >
          <span></span><span></span>
        </button>
      </div>
      <nav aria-label="Mobile navigation links">
        {
          navigationItems.map((item, index) => (
            <a
              href={withBase(base, item.path)}
              aria-current={
                isActiveNavigationPath(currentPath, item) ? "page" : undefined
              }
              rel={item.external ? "noreferrer" : undefined}
              data-drawer-link
            >
              <span class="mobile-drawer-index">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span>{item.label}</span>
              <span aria-hidden="true">↗</span>
            </a>
          ))
        }
      </nav>
      <p>Spec-driven orchestration for coding-agent teams.</p>
    </aside>
  </div>

  <noscript>
    <style>
      @media (max-width: 48rem) {
        .primary-nav {
          display: flex;
          position: absolute;
          top: 100%;
          right: 0;
          left: 0;
          padding: 0.9rem 1rem;
          overflow-x: auto;
          border: 1px solid var(--line);
          background: var(--surface-raised);
        }
        .mobile-menu-button {
          display: none;
        }
      }
    </style>
  </noscript>
</header>

<script>
  const initializeDrawer = (header: HTMLElement) => {
    if (header.dataset.drawerReady === "true") return;
    header.dataset.drawerReady = "true";

    const openButton = header.querySelector<HTMLButtonElement>("[data-drawer-open]");
    const closeButton = header.querySelector<HTMLButtonElement>("[data-drawer-close]");
    const backdrop = header.querySelector<HTMLButtonElement>("[data-drawer-backdrop]");
    const layer = header.querySelector<HTMLElement>("[data-drawer-layer]");
    const drawer = header.querySelector<HTMLElement>("[data-drawer]");
    const links = Array.from(
      header.querySelectorAll<HTMLAnchorElement>("[data-drawer-link]"),
    );
    if (!openButton || !closeButton || !backdrop || !layer || !drawer) return;

    let isOpen = false;
    let previousOverflow = "";

    const focusableElements = () =>
      Array.from(
        drawer.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
        ),
      );

    const setBackgroundInert = (inert: boolean) => {
      const main = document.querySelector<HTMLElement>("main");
      if (main) main.inert = inert;
      header.querySelector<HTMLElement>(".brand")!.inert = inert;
      header.querySelector<HTMLElement>(".primary-nav")!.inert = inert;
    };

    const closeDrawer = (restoreFocus = true) => {
      if (!isOpen) return;
      isOpen = false;
      layer.classList.remove("is-open");
      openButton.setAttribute("aria-expanded", "false");
      document.body.classList.remove("drawer-open");
      document.body.style.overflow = previousOverflow;
      setBackgroundInert(false);
      window.setTimeout(() => {
        if (!isOpen) layer.hidden = true;
      }, window.matchMedia("(prefers-reduced-motion: reduce)").matches ? 0 : 220);
      if (restoreFocus) openButton.focus();
    };

    const openDrawer = () => {
      if (isOpen) return;
      isOpen = true;
      previousOverflow = document.body.style.overflow;
      layer.hidden = false;
      openButton.setAttribute("aria-expanded", "true");
      document.body.classList.add("drawer-open");
      document.body.style.overflow = "hidden";
      setBackgroundInert(true);
      window.requestAnimationFrame(() => {
        layer.classList.add("is-open");
        closeButton.focus();
      });
    };

    openButton.addEventListener("click", openDrawer);
    closeButton.addEventListener("click", () => closeDrawer());
    backdrop.addEventListener("click", () => closeDrawer());
    links.forEach((link) =>
      link.addEventListener("click", () => closeDrawer(false)),
    );

    document.addEventListener("keydown", (event) => {
      if (!isOpen) return;
      if (event.key === "Escape") {
        event.preventDefault();
        closeDrawer();
        return;
      }
      if (event.key !== "Tab") return;
      const focusable = focusableElements();
      const first = focusable[0];
      const last = focusable.at(-1);
      if (!first || !last) return;
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 48.0625rem)").matches) {
        closeDrawer(false);
        const activeDesktopLink = header.querySelector<HTMLAnchorElement>(
          '.primary-nav a[aria-current="page"]',
        );
        (activeDesktopLink ?? header.querySelector<HTMLAnchorElement>(".brand"))?.focus();
      }
    });
  };

  document
    .querySelectorAll<HTMLElement>("[data-site-header]")
    .forEach(initializeDrawer);
</script>
