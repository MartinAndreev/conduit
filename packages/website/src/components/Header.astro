---
interface Props {
  readonly base: string;
  readonly repositoryUrl: string;
}

const { base, repositoryUrl } = Astro.props;
---

<header class="site-header">
  <a class="brand" href={`${base}#top`} aria-label="Conduit home">
    <img src={`${base}conduit-logo.svg`} alt="Conduit" />
  </a>

  <nav aria-label="Primary navigation">
    <a href={`${base}#demo`}>Demo</a>
    <a href={`${base}#why`}>Why</a>
    <a href={`${base}#cli`}>CLI</a>
    <a href={`${base}#install`}>Install</a>
    <a href={`${base}docs/`}>Docs</a>
  </nav>

  <a class="github-link" href={repositoryUrl}>
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path
        fill="currentColor"
        d="M12 .7a11.5 11.5 0 0 0-3.64 22.4c.58.11.79-.25.79-.56v-2.22c-3.22.7-3.9-1.37-3.9-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.72 1.27 3.38.97.1-.75.41-1.27.74-1.56-2.57-.29-5.27-1.29-5.27-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.47.11-3.05 0 0 .97-.31 3.16 1.18a10.9 10.9 0 0 1 5.76 0c2.19-1.49 3.16-1.18 3.16-1.18.63 1.58.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.4-2.71 5.38-5.29 5.67.42.36.79 1.06.79 2.14v3.18c0 .31.21.68.8.56A11.5 11.5 0 0 0 12 .7Z"
      ></path>
    </svg>
    <span>GitHub</span>
  </a>
</header>
