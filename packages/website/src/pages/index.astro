---
import Hero from "../components/Hero.astro";
import CliFlow from "../components/CliFlow.astro";
import Install from "../components/Install.astro";
import Principles from "../components/Principles.astro";
import Storage from "../components/Storage.astro";
import TerminalDemo from "../components/TerminalDemo.astro";
import WhyBuilt from "../components/WhyBuilt.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { repositoryUrl } from "../data/navigation.js";

const base = import.meta.env.BASE_URL;
---

<SiteLayout
  title="Conduit — orchestrate coding-agent teams"
  description="Conduit turns approved feature specifications into focused, observable coding-agent work."
>
  <main id="top">
    <Hero base={base} repositoryUrl={repositoryUrl} />
    <TerminalDemo />
    <WhyBuilt />
    <CliFlow />
    <Storage />
    <Install base={base} repositoryUrl={repositoryUrl} />
    <Principles />
  </main>
</SiteLayout>
