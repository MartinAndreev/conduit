{
  "name": "conduit-orchestrator",
  "version": "0.5.4",
  "description": "Spec-driven, local-first orchestration for coding agents.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "docs",
    "skills",
    "README.md"
  ],
  "bin": {
    "conduit": "./dist/conduit.js"
  },
  "scripts": {
    "build": "bun scripts/build.js",
    "build:standalone": "bun scripts/build-standalone.js",
    "generate:role-templates": "bun scripts/generate-role-templates.js",
    "install:local": "mkdir -p \"$HOME/.local/bin\" && install -m 755 dist/release/conduit-linux-x64 \"$HOME/.local/bin/conduit\"",
    "prepack": "pnpm build",
    "release:checksums": "node scripts/write-checksums.mjs",
    "lint": "eslint .",
    "start": "tsx ./bin/conduit.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.4.3",
    "@opentui/react": "^0.4.3",
    "@tursodatabase/database": "^0.7.0",
    "@tursodatabase/database-common": "^0.7.0",
    "commander": "^14.0.0",
    "kysely": "^0.29.3",
    "ora": "^9.3.0",
    "react": "^19.2.7",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=22"
  },
  "optionalDependencies": {
    "@tursodatabase/database-darwin-arm64": "0.7.0",
    "@tursodatabase/database-linux-arm64-gnu": "0.7.0",
    "@tursodatabase/database-linux-x64-gnu": "0.7.0",
    "@tursodatabase/database-win32-x64-msvc": "0.7.0"
  }
}
